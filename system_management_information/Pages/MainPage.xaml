<Page x:Class="system_management_information.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:system_management_information.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="MainPage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
            <Image Margin="30" Source="/Media/logo_vizit.png" Height="120" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <Border Background="red" CornerRadius="20" Margin="10">
                <Button Content="Достопримечательности" Margin="10" Click="GoToSights" />
            </Border>
            <Border Background="red" CornerRadius="20" Margin="10">
                <Button Content="Мероприятия" Margin="10" Click="GoToEvents"/>
            </Border>
            <Border Background="red" CornerRadius="20" Margin="10">
                <Button Content="Гостиницы" Margin="10" Click="GoToHotels"/>
            </Border>
            <Border Background="red" CornerRadius="20" Margin="10">
                <Button Content="Места общепита" Margin="10" Click="GoToCatering"/>
            </Border>
            <Border Background="red" CornerRadius="20" Margin="10">
                <Button Content="Сувениры" Margin="10" Click="GoToSouvenirs"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>
