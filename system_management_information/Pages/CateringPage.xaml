<Page x:Class="system_management_information.Pages.CateringPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:system_management_information.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CateringPage">

    <Grid>
        <Border Style="{StaticResource BackBorder}">
            <Button Style="{StaticResource BackButton}" Click="GoBack" Content="Назад"/>
        </Border>
        <TextBlock Style="{StaticResource LabelPage}" Text="Места общепита"/>
        <TextBlock Style="{StaticResource TextFound}" Text="Поиск: "/>
        <Border CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="100,60,30,0" BorderThickness="1">
            <TextBox x:Name="foundCateringText" MaxLength="30" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman" TextChanged="FoundCatering"/>
        </Border>
        <Border CornerRadius="20" Margin="20,100,20,70" Background="#95a5a6">
            <ListBox x:Name="ListCaterings" ItemsSource="{Binding listCaterings}" Margin="15" Background="#95a5a6" MinHeight="0" BorderBrush="#95a5a6" Padding="0" VerticalAlignment="Top" SelectionChanged="ToEditCatering">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="Width" Value="Auto"/>
                    </Style>

                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Background="White" BorderBrush="White" BorderThickness="0" HorizontalAlignment="Stretch" CornerRadius="10">
                            <Grid Margin="20" Background="White">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="0.5*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Категория заведения:  "/>
                                        <TextBlock Text="{Binding establishmentCategory}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Название заведения:  "/>
                                        <TextBlock Text="{Binding establishmentName}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Адрес:  "/>
                                        <TextBlock Text="{Binding addressCatering}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Контактный номер:  "/>
                                        <TextBlock Text="{Binding establishmentPhone}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Url заведения:  "/>
                                        <TextBlock  FontSize="16" FontFamily="Times New Roman" Text="{Binding urlCatering}">
                                    <Hyperlink NavigateUri="{Binding hyperlinkCatering}" RequestNavigate="ToSiteCatering" >
                                        <TextBlock Text="{Binding hyperlinkCatering}"/>
                                    </Hyperlink>
                                </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Типы кухни:  "/>
                                        <TextBlock Text="{Binding typesKitchen}" FontSize="16" FontFamily="Times New Roman"/>
                                    
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="График работы:  "/>
                                        <TextBlock Text="{Binding operationModeCatering}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Visibility="{Binding visibilityTickets}">
                                    <TextBlock VerticalAlignment="Top" HorizontalAlignment="Left" Margin="5" FontWeight="Bold" FontSize="20" FontFamily="Times New Roman" Text=""/>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10" FontSize="16" FontFamily="Times New Roman" Text="{Binding tickets}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20,10">
            <Border Style="{StaticResource BackBorder}" Width="150" Height="35">
                <Button Content="Добавить" Style="{StaticResource BackButton}" Click="ToAddEvent"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>
