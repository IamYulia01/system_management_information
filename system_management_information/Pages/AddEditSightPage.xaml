<Page x:Class="system_management_information.Pages.AddEditSightPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:system_management_information.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="AddEditSightPage">

    <Grid>
        <Border Style="{StaticResource BackBorder}">
            <Button Style="{StaticResource BackButton}" Click="GoBack" Content="Назад"/>
        </Border>
        <TextBlock x:Name="titlePage"  Style="{StaticResource LabelPage}" Text="Достопримечательность"/>
        <StackPanel Margin="50,70,50,50" Height="400" VerticalAlignment="Top">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Тип достопримечательности:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="typeSight" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Название:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="nameSight" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Описание:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="descriptionSight" MaxLength="900" TextWrapping="Wrap" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Улица:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="streetSight" MaxLength="50" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
                <TextBlock Grid.Column="2"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="     Дом:  "/>
                <Border Grid.Column="3" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="houseSight" MaxLength="10" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="E-mail:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="emailSight" MaxLength="50" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
                <TextBlock Grid.Column="2"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="     Контактный номер:  "/>
                <Border Grid.Column="3" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="contactNumberSight" MaxLength="20" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Url достопримечательности:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="urlSight" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
        </StackPanel>
        <TextBlock Style="{StaticResource NameDescription}" VerticalAlignment="Top" HorizontalAlignment="Center" Text="График работы" Margin="0,480,0,0" FontSize="20"/>
        <Border Background="#95a5a6" Margin="50,505,50,60" CornerRadius="15">
            <Grid>
                <ListBox x:Name="ListOperatingModes" ItemsSource="{Binding listOperatingModes}" Margin="5,5,5,60" Background="#95a5a6" BorderBrush="#95a5a6" SelectionChanged="EditOperatingMode">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="Width" Value="Auto"/>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Background="White" Margin="5"  HorizontalAlignment="Stretch">
                                <Grid Margin="5" Height="50">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Margin="10" HorizontalAlignment="Left" Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="{Binding time}"/>
                                    <TextBlock Grid.Column="1" Margin="10" HorizontalAlignment ="Right" Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="{Binding day}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5">
                    <Border Style="{StaticResource BackBorder}" Width="200" Height="30">
                        <Button Content="Добавить график" Style="{StaticResource BackButton}" Click="AddDay"/>
                    </Border>
                    <Border Style="{StaticResource BackBorder}" Width="200" Height="30">
                        <Button Content="Добавить специальный день" Style="{StaticResource BackButton}" Click="AddSpecialDay"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <Border Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="40,10">
                <Button Content="Сохранить" Style="{StaticResource BackButton}" Click="SaveSight"/>
            </Border>
            <Border x:Name="btnDelete" Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="40,10">
                <Button Content="Удалить" Style="{StaticResource BackButton}" Click="DeleteSight"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>
