<Page x:Class="system_management_information.Pages.AddEditHotelPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:system_management_information.Pages"
      mc:Ignorable="d" d:DesignWidth="800"
      Title="AddEditHotelPage">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Border Style="{StaticResource BackBorder}">
                    <Button Style="{StaticResource BackButton}" Click="GoBack" Content="Назад"/>
                </Border>
                <TextBlock x:Name="titlePage"  Style="{StaticResource LabelPage}" Text="Гостиница"/>
                <StackPanel Margin="50,70,50,50" Height="250" VerticalAlignment="Top">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Тип гостиницы:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <ComboBox x:Name="typeHotel" Foreground="Black" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman" SelectionChanged="SelectionTypeHotel"/>
                        </Border>
                    </Grid>
                    <Grid x:Name="otherView" Margin="10" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Другое:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="otherTypeCatering" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Название:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="nameHotel" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="0.5*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Улица:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="streetHotel" MaxLength="50" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                        <TextBlock Grid.Column="2"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="     Дом:  "/>
                        <Border Grid.Column="3" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="houseHotel" MaxLength="10" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Контактный номер:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="contactNumberHotel" MaxLength="20" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Url гостиницы:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="urlHotel" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                </StackPanel>
                
                <TextBlock Style="{StaticResource NameDescription}" VerticalAlignment="Top" HorizontalAlignment="Center" Text="Фотографии" Margin="0,350,0,0" FontSize="20"/>
                <Border Background="#95a5a6" Margin="50,375,50,90" VerticalAlignment="Top" Height="370"  CornerRadius="15">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="❮" VerticalAlignment="Stretch" Width="30" Click="ListToLeft" Background="#95a5a6"/>
                        <ListView x:Name="ListPhotos" Grid.Column="1" ItemsSource="{Binding listPhotos}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled" Margin="10" Background="#95a5a6" BorderBrush="#95a5a6">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Background="White" Margin="5" Height="250">
                                        <StackPanel Margin="5">
                                            <Image Source="{Binding photo}" Height="200"/>
                                            <TextBlock Text="{Binding shortDescription}" Style="{StaticResource NameDescription}" Margin="1" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="25">
                            <Border Style="{StaticResource BackBorder}" Width="150" Height="30">
                                <Button Content="Добавить" Style="{StaticResource BackButton}" Click="AddPhoto"/>
                            </Border>
                            <Border Style="{StaticResource BackBorder}" Width="150" Height="30">
                                <Button Content="Удалить" Style="{StaticResource BackButton}" Click="DeletePhoto"/>
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="2" Background="#95a5a6" Content="❯" VerticalAlignment="Stretch" Width="30" Click="ListToRight"/>
                    </Grid>

                </Border>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="30">
                    <Border Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="40,10">
                        <Button Content="Сохранить" Style="{StaticResource BackButton}" Click="SaveHotel"/>
                    </Border>
                    <Border x:Name="btnDelete" Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="40,10">
                        <Button Content="Удалить" Style="{StaticResource BackButton}" Click="DeleteHotel"/>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
