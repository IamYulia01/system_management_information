<Page x:Class="system_management_information.Pages.HotelsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:system_management_information.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HotelsPage">

    <Grid>
        <Border Style="{StaticResource BackBorder}">
            <Button Style="{StaticResource BackButton}" Click="GoBack" Content="Назад"/>
        </Border>
        <TextBlock Style="{StaticResource LabelPage}" Text="Гостиницы"/>
        <TextBlock Style="{StaticResource TextFound}" Text="Поиск: "/>
        <Border CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="100,60,30,0" BorderThickness="1">
            <TextBox x:Name="foundHotelText" MaxLength="30" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman" TextChanged="FoundHotel"/>
        </Border>
        <Border CornerRadius="20" Margin="20,100,20,70" Background="#95a5a6">
            <ListBox x:Name="ListHotels" ItemsSource="{Binding listHotels}" Margin="15" Background="#95a5a6" MinHeight="0" BorderBrush="#95a5a6" Padding="0" VerticalAlignment="Top" SelectionChanged="ToEditHotel">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="Width" Value="Auto"/>
                    </Style>

                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Background="White" BorderBrush="White" BorderThickness="0" HorizontalAlignment="Stretch" CornerRadius="10">
                            <Grid Margin="20" Background="White">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="10">
                                    <Image Source="{Binding photoHotel}" MaxWidth="300"/>
                                </Grid>
                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Тип заведения:  "/>
                                        <TextBlock Text="{Binding typeHotel}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Название гостиницы:  "/>
                                        <TextBlock Text="{Binding hotelName}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Адрес:  "/>
                                        <TextBlock Text="{Binding addressHotel}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Контактный номер:  "/>
                                        <TextBlock Text="{Binding contactNumberHotel}" FontSize="16" FontFamily="Times New Roman"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource NameDescription}" Text="Url гостиницы:  "/>
                                        <TextBlock  FontSize="16" FontFamily="Times New Roman" Text="{Binding hotelUrl}">
                                    <Hyperlink NavigateUri="{Binding hyperlinkHotel}" RequestNavigate="ToSiteHotel" >
                                        <TextBlock Text="{Binding hyperlinkHotel}"/>
                                    </Hyperlink>
                                </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="20,10">
            <Border Style="{StaticResource BackBorder}" Width="150" Height="35">
                <Button Content="Добавить" Style="{StaticResource BackButton}" Click="ToAddHotel" Height="25" Margin="5,5,5,0" VerticalAlignment="Top"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>
