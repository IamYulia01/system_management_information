<Page x:Class="system_management_information.Pages.AddEditEventPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:system_management_information.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditEventPage">

    <Grid>
        <Border Style="{StaticResource BackBorder}">
            <Button Style="{StaticResource BackButton}" Click="GoBack" Content="Назад"/>
        </Border>
        <TextBlock x:Name="titlePage"  Style="{StaticResource LabelPage}" Text="Мероприятие"/>
        <StackPanel Margin="50,70,50,50" Height="250" VerticalAlignment="Top">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Тип мероприятия:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="typeEvent" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Название:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="nameEvent" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Улица:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="streetEvent" MaxLength="50" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
                <TextBlock Grid.Column="2"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="     Дом:  "/>
                <Border Grid.Column="3" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="houseEvent" MaxLength="10" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0.6*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text=" Возрастное ограничение:  "/>
                <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <TextBox x:Name="ageLimit" MaxLength="10" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
                <TextBlock Grid.Column="2"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="    Дата проведения:  "/>
                <Border Grid.Column="3" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <DatePicker x:Name="dateEvent" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6"  Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Background" Value="#95a5a6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Text" Value=" "/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>
                </Border>
                <TextBlock Grid.Column="4"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="     Время начала:  "/>
                <Border Grid.Column="5" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                    <xctk:MaskedTextBox x:Name="timeEvent" Value="00:00" Margin="20,7" Mask="00:00" Foreground="White" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                </Border>
            </Grid>
        </StackPanel>
        <TextBlock Style="{StaticResource NameDescription}" VerticalAlignment="Top" HorizontalAlignment="Center" Text="Билеты" Margin="0,290,0,0" FontSize="20"/>
        <Border Background="#95a5a6" Margin="50,315,50,60" CornerRadius="15">
            <Grid>
                <ListBox x:Name="ListTickets" ItemsSource="{Binding listTickets}" Margin="5,5,5,60" Background="#95a5a6" BorderBrush="#95a5a6" SelectionChanged="EditTicket">
                <ListBox.Resources>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="Width" Value="Auto"/>
                    </Style>
                </ListBox.Resources>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" Background="White" Margin="5"  HorizontalAlignment="Stretch">
                            <Grid Margin="5" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Margin="10" HorizontalAlignment="Left" Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="{Binding ages}"/>
                                <TextBlock Grid.Column="1" Margin="10" HorizontalAlignment ="Center" Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="{Binding price}"/>
                                <TextBlock Grid.Column="2" Margin="10" HorizontalAlignment="Right" Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="{Binding countPeople}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5">
                    <Border Style="{StaticResource BackBorder}" Width="150" Height="30">
                        <Button Content="Добавить билет" Style="{StaticResource BackButton}" Click="AddTicket"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
            <Border Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="40,10">
                <Button Content="Сохранить" Style="{StaticResource BackButton}" Click="SaveEvent"/>
            </Border>
            <Border x:Name="btnDelete" Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="40,10">
                <Button Content="Удалить" Style="{StaticResource BackButton}" Click="DeleteEvent"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>
