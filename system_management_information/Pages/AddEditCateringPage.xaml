<Page x:Class="system_management_information.Pages.AddEditCateringPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:system_management_information.Pages"
      mc:Ignorable="d" d:DesignWidth="800"
      Title="AddEditCateringPage">

    <Grid>
        <ScrollViewer Margin="0">
            <Grid>
                <Border Style="{StaticResource BackBorder}">
                    <Button Style="{StaticResource BackButton}" Click="GoBack" Content="Назад"/>
                </Border>
                <TextBlock x:Name="titlePage"  Style="{StaticResource LabelPage}" Text="Место общепита"/>
                <StackPanel Margin="50,70,50,50" Height="310" VerticalAlignment="Top">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Категория заведения:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <ComboBox x:Name="categoryCatering" Foreground="Black" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman" SelectionChanged="SelectCategoryCatering"/>
                        </Border>
                    </Grid>
                    <Grid x:Name="otherView" Margin="10" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Другое:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="otherTypeCatering" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Название:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="nameCatering" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="0.5*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Улица:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="streetCatering" MaxLength="50" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                        <TextBlock Grid.Column="2"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="     Дом:  "/>
                        <Border Grid.Column="3" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="houseCatering" MaxLength="10" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Контактный номер:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="contactNumberCatering" MaxLength="20" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Url общепита:  "/>
                        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                            <TextBox x:Name="urlCatering" MaxLength="100" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                        </Border>
                    </Grid>
                </StackPanel>
                <TextBlock Style="{StaticResource NameDescription}" VerticalAlignment="Top" HorizontalAlignment="Center" Text="График работы" Margin="0,390,0,0" FontSize="20"/>
                <Border Background="#95a5a6" Margin="50,415,50,60" VerticalAlignment="Top" Height="300" CornerRadius="15">
                    <Grid>
                        <ListBox x:Name="ListOperatingModes" ItemsSource="{Binding listOperatingModes}" Margin="5,5,5,60" Background="#95a5a6" BorderBrush="#95a5a6" SelectionChanged="EditOperatingMode">
                            <ListBox.Resources>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="Width" Value="Auto"/>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Background="White" Margin="5"  HorizontalAlignment="Stretch">
                                        <Grid Margin="5" Height="50">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Margin="10" HorizontalAlignment="Left" Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="{Binding time}"/>
                                            <TextBlock Grid.Column="1" Margin="10" HorizontalAlignment ="Right" Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="{Binding day}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5">
                            <Border Style="{StaticResource BackBorder}" Width="250" Height="30">
                                <Button Content="Добавить график" Style="{StaticResource BackButton}" Click="AddDay"/>
                            </Border>
                            <Border Style="{StaticResource BackBorder}" Width="250" Height="30">
                                <Button Content="Добавить специальный день" Style="{StaticResource BackButton}" Click="AddSpecialDay"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Style="{StaticResource NameDescription}" VerticalAlignment="Top" HorizontalAlignment="Center" Text="Типы кухни" Margin="0,750,0,0" FontSize="20"/>
                <Border Background="#95a5a6" Margin="50,775,50,60" CornerRadius="15"  VerticalAlignment="Top" Height="300">
                    <Grid>
                            <ListBox x:Name="ListTypesKitchen" Background="#95a5a6" Margin="5,5,5,60" ItemsSource="{Binding listTypesKitchen}" SelectionMode="Single" SelectedItem="{Binding SelectedCuisineType}">
                                <ListBox.Resources>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        <Setter Property="Width" Value="Auto"/>
                                    </Style>
                                </ListBox.Resources>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Background="White" Margin="5" HorizontalAlignment="Stretch">
                                            <Grid Margin="5" Height="40">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="10,0,0,0" Background="#95a5a6" IsChecked="{Binding isHave}" Tag="{Binding idType}" Checked="AddCateringTypeKitchen" Unchecked="DeleteCateringTypeKitchen"/>
                                                <TextBlock Grid.Column="1" Margin="10" HorizontalAlignment="Left" Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="{Binding type}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5">
                            
                            <Border Style="{StaticResource BackBorder}" Width="200" Height="30">
                                <Button Content="Удалить тип кухни" Style="{StaticResource BackButton}" Click="DeleteTypeKitchen"/>
                            </Border>
                        </StackPanel>
                        
                    </Grid>
                </Border>

                <Grid Margin="50,1100,50,60" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Новый тип кухни:  "/>
                    <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Center" HorizontalAlignment="Stretch" BorderThickness="1">
                        <TextBox x:Name="newTypeKitchen" MaxLength="50" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="10,0">
                        <Button Content="Добавить" Style="{StaticResource BackButton}" Click="AddTypeKitchen"/>
                    </Border>
                </Grid>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <Border Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="40,10">
                        <Button Content="Сохранить" Style="{StaticResource BackButton}" Click="SaveCatering"/>
                    </Border>
                    <Border x:Name="btnDelete" Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="40,10">
                        <Button Content="Удалить" Style="{StaticResource BackButton}" Click="DeleteCatering"/>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
