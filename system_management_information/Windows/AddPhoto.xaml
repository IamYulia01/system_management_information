<Window x:Class="system_management_information.Windows.AddPhoto"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:system_management_information.Windows"
        mc:Ignorable="d"
        Icon="/Media/icon.ico"
        Title="Приложение администратора базы данных" Height="450" Width="800">
    <Grid>
        <Border Style="{StaticResource BackBorder}">
            <Button Style="{StaticResource BackButton}" Click="GoBack" Content="Назад"/>
        </Border>
        <TextBlock x:Name="titlePage"  Style="{StaticResource LabelPage}" Text="Добавление фотографии"/>
        <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" Margin="100,70,100,125" BorderThickness="1" AllowDrop="True" Drop="DropPhoto">
            <Grid>
                <TextBlock x:Name="NoImage" FontSize="24" Text="Перетащите изображение сюда" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" Background="#95a5a6" Margin="5" FontFamily="Times New Roman"/>
                <Image x:Name="image" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="50"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                    <Border Style="{StaticResource BackBorder}" Width="150" Height="30">
                        <Button Content="Загрузить" Style="{StaticResource BackButton}" Click="DownloadPhoto"/>
                    </Border>
                    <Border x:Name="btnDelete" Style="{StaticResource BackBorder}" Width="150" Height="30">
                        <Button Content="Удалить" Style="{StaticResource BackButton}" Click="DeletePhoto"/>
                    </Border>
                </StackPanel>
                
            </Grid>            
        </Border>
        <Grid VerticalAlignment="Bottom" Margin="100,79">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"  Style="{StaticResource NameDescription}" VerticalAlignment="Center" Text="Описание фотогафии:  "/>
            <Border Grid.Column="1" CornerRadius="10" Background="#95a5a6" VerticalAlignment="Top" HorizontalAlignment="Stretch" BorderThickness="1">
                <TextBox x:Name="description" MaxLength="4" Foreground="White" Background="#95a5a6" BorderBrush="#95a5a6" Margin="5" BorderThickness="0" FontSize="16" FontFamily="Times New Roman"/>
            </Border>
        </Grid>
        <Border Style="{StaticResource BackBorder}" Width="150" Height="35" Margin="30" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Button Content="Сохранить" Style="{StaticResource BackButton}" Click="SavePhoto"/>
        </Border>
    </Grid>
</Window>
